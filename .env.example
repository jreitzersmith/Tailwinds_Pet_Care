# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it's already in .gitignore.

# Supabase — https://supabase.com/dashboard/project/_/settings/api

	# Project URL (Settings → API → Project URL)
	VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

	# Anon/public key — safe to use in frontend code (RLS enforces access control)
	VITE_SUPABASE_ANON_KEY=

	# Service role key — used for schema setup ONLY, never expose in frontend code
	SUPABASE_SERVICE_KEY=

	# Management token (account-level)
	SUPABASE_MANAGEMENT_TOKEN=

# Google Maps — https://console.cloud.google.com/apis/credentials
	# Maps JavaScript API key — restrict to tailwindspetcare.com in GCP console
	VITE_GOOGLE_MAPS_API_KEY=

# GitHub — https://github.com/settings/tokens
	# Personal Access Token (classic) with repo scope
	GITHUB_TOKEN=ghp_...

# Square — https://developer.squareup.com/apps (Phase 3)
	# Production credentials
	VITE_SQUARE_APP_ID_PROD=
	VITE_SQUARE_LOCATION_ID_PROD=

	# Sandbox credentials (used when VITE_SQUARE_ENV=sandbox)
	VITE_SQUARE_APP_ID_SANDBOX=
	VITE_SQUARE_LOCATION_ID_SANDBOX=

	# Set to 'sandbox' for testing, 'production' for live
	VITE_SQUARE_ENV=sandbox

# PayPal — https://developer.paypal.com/dashboard/ (Phase 3)
	# Client IDs are safe in frontend code
	VITE_PAYPAL_CLIENT_ID_SANDBOX=
	VITE_PAYPAL_CLIENT_ID_PROD=

	# Secrets are server-side ONLY — never prefix with VITE_
	PAYPAL_SECRET_SANDBOX=
	PAYPAL_SECRET_PROD=
